# --- Database ---
# Compose sets this for the app container; override for local dev.
DATABASE_URL="postgresql://mealplanner:mealplanner@localhost:5432/mealplanner?schema=public"

# --- Anthropic API (server-side recipe parsing) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Household shared login (§9) ---
# The single shared password gating the app. Tailscale is the primary gate;
# this is defense-in-depth. Set to a real value in production.
HOUSEHOLD_PASSWORD="change-me"
# Secret used to sign the session cookie.
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Postgres container (docker-compose) ---
POSTGRES_USER=mealplanner
POSTGRES_PASSWORD=mealplanner
POSTGRES_DB=mealplanner
